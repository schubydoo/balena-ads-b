{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":disableRateLimiting"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\s(ARG|ENV) .*?_VERSION=(?<currentValue>.*)\\s"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)wingbits/Dockerfile\\.template$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ENV WINGBITS_COMMIT_ID=(?<currentValue>.*?)\\n",
        "ENV WINGBITS_DATE=(?<currentDigest>.*?)\\n"
      ],
      "depNameTemplate": "wingbits-meta",
      "datasourceTemplate": "custom.wingbits-meta"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)wingbits/Dockerfile\\.template$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ENV WINGBITS_COMMIT_ID=(?<currentValue>.*?)\\n",
        "ENV WINGBITS_SHA256_AMD64=(?<currentDigest>.*?)\\n"
      ],
      "depNameTemplate": "wingbits-binary-amd64",
      "packageNameTemplate": "amd64",
      "datasourceTemplate": "custom.wingbits-binary"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)wingbits/Dockerfile\\.template$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ENV WINGBITS_COMMIT_ID=(?<currentValue>.*?)\\n",
        "ENV WINGBITS_SHA256_ARM64=(?<currentDigest>.*?)\\n"
      ],
      "depNameTemplate": "wingbits-binary-arm64",
      "packageNameTemplate": "arm64",
      "datasourceTemplate": "custom.wingbits-binary"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)wingbits/Dockerfile\\.template$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ENV WINGBITS_COMMIT_ID=(?<currentValue>.*?)\\n",
        "ENV WINGBITS_SHA256_ARM=(?<currentDigest>.*?)\\n"
      ],
      "depNameTemplate": "wingbits-binary-arm",
      "packageNameTemplate": "arm",
      "datasourceTemplate": "custom.wingbits-binary"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "WINGBITS_CONFIG_VERSION=(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "wingbits-version",
      "datasourceTemplate": "custom.wingbits-version",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "MLAT_VERSION=(?<currentDigest>.*?)\\n"
      ],
      "currentValueTemplate": "master",
      "packageNameTemplate": "https://github.com/wiedehopf/mlat-client",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "SOAPYRTLSDR_VERSION=(?<currentDigest>.*?)\\n"
      ],
      "currentValueTemplate": "master",
      "packageNameTemplate": "https://github.com/pothosware/SoapyRTLSDR",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "AIRSPY_VERSION=(?<currentDigest>.*?)\\n"
      ],
      "currentValueTemplate": "master",
      "packageNameTemplate": "https://github.com/wiedehopf/airspy-conf",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "PIAWARE_BUILDER_REF=(?<currentDigest>.*?)\\n"
      ],
      "currentValueTemplate": "dev",
      "packageNameTemplate": "https://github.com/flightaware/piaware_builder",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile\\.[^/]*$/"
      ],
      "matchStrings": [
        "TAR1090_NGINX_REF=(?<currentDigest>.*?)\\n"
      ],
      "currentValueTemplate": "master",
      "packageNameTemplate": "https://github.com/wiedehopf/tar1090",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)autohupr/Dockerfile\\.template$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG ALPINE_VERSION=(?<alpineVer>\\S+)",
        "# renovate: alpine-package=nodejs\\s+ARG NODEJS_VERSION=(?<currentValue>\\d+)"
      ],
      "depNameTemplate": "alpine_{{replace \"\\.\" \"_\" alpineVer}}/nodejs",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^(?<version>\\d+)"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)autohupr/Dockerfile\\.template$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "ARG ALPINE_VERSION=(?<alpineVer>\\S+)",
        "# renovate: alpine-package=npm\\s+ARG NPM_VERSION=(?<currentValue>\\d+)"
      ],
      "depNameTemplate": "alpine_{{replace \"\\.\" \"_\" alpineVer}}/npm",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^(?<version>\\d+)"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)planefinder/Dockerfile\\.template$/"
      ],
      "matchStrings": [
        "PLANEFINDER_VERSION_AMD64=(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "planefinder-binary-amd64",
      "datasourceTemplate": "custom.planefinder-binary-amd64"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)planefinder/Dockerfile\\.template$/"
      ],
      "matchStrings": [
        "PLANEFINDER_VERSION_ARM64=(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "planefinder-binary-arm64",
      "datasourceTemplate": "custom.planefinder-binary-arm64"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)planefinder/Dockerfile\\.template$/"
      ],
      "matchStrings": [
        "PLANEFINDER_VERSION_ARMHF=(?<currentValue>.*?)\\n"
      ],
      "depNameTemplate": "planefinder-binary-armhf",
      "datasourceTemplate": "custom.planefinder-binary-armhf"
    }
  ],
  "customDatasources": {
    "flightradar24": {
      "defaultRegistryUrlTemplate": "https://s3.dualstack.us-east-1.amazonaws.com/repo.feed.flightradar24.com/fr24feed_versions.json",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $.platform.linux_arm64_tgz.version}]}"
      ]
    },
    "wingbits-version": {
      "defaultRegistryUrlTemplate": "https://gitlab.com/wingbits/config/-/raw/master/download.sh",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": $trim($[0].releases.version.$match(/WINGBITS_CONFIG_VERSION=\"([^\\s]+)\"/).groups[0]) }] }"
      ],
      "format": "plain"
    },
    "wingbits-meta": {
      "defaultRegistryUrlTemplate": "https://install.wingbits.com/linux-arm64.json",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $.Version, \"digest\": $.Date}]}"
      ]
    },
    "wingbits-binary": {
      "defaultRegistryUrlTemplate": "https://install.wingbits.com/linux-{{packageName}}.json",
      "transformTemplates": [
        "{\"releases\":[{\"version\": $.Version, \"digest\": $.Sha256}]}"
      ]
    },
    "planefinder-binary-amd64": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/sdr-enthusiasts/docker-planefinder/main/Dockerfile",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": $[0].releases.version.$match(/pfclient_([0-9.]+)_amd64\\.tar\\.gz/).groups[0] }] }"
      ],
      "format": "plain"
    },
    "planefinder-binary-arm64": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/sdr-enthusiasts/docker-planefinder/main/Dockerfile",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": $[0].releases.version.$match(/pfclient_([0-9.]+)_arm64\\.tar\\.gz/).groups[0] }] }"
      ],
      "format": "plain"
    },
    "planefinder-binary-armhf": {
      "defaultRegistryUrlTemplate": "https://raw.githubusercontent.com/sdr-enthusiasts/docker-planefinder/main/Dockerfile",
      "transformTemplates": [
        "{ \"releases\": [{ \"version\": $[0].releases.version.$match(/pfclient_([0-9.]+)_armhf\\.tar\\.gz/).groups[0] }] }"
      ],
      "format": "plain"
    }
  },
  "packageRules": [
    {
      "matchDatasources": [
        "custom.wingbits-version",
        "custom.wingbits-meta",
        "custom.wingbits-binary"
      ],
      "groupName": "wingbits version to latest",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "separateMultipleMajor": false
    }
  ],
  "logLevelRemap": [
    {
      "matchMessage": "/^Custom manager fetcher/",
      "newLogLevel": "info"
    }
  ]
}
